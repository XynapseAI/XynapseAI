{
  "version": 2,
  "framework": "nextjs",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "methods": ["GET", "POST"],
      "headers": {
        "Access-Control-Allow-Origin": "https://xynapse-ai.vercel.app",
        "Access-Control-Allow-Methods": "GET, POST",
        "Access-Control-Allow-Headers": "Authorization, Content-Type, x-recaptcha-token"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "NEXT_PUBLIC_APP_URL": "https://xynapse-ai.vercel.app",
    "SIM_API_KEY": "@sim_api_key",
    "COINGECKO_API_KEY": "@coingecko_api_key"
  },
  "functions": {
    "pages/api/**/*.js": {
      "maxDuration": 30
    }
  }
}