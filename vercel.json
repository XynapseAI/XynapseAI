{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "app.xynapseai.net"
        }
      ],
      "destination": "/dashboard/:path*"
    },
    {
      "source": "/api/:path*",
      "has": [
        {
          "type": "host",
          "value": "api.xynapseai.net"
        }
      ],
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://app.xynapseai.net"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type,X-Recaptcha-Token,X-Internal-Token"
        }
      ]
    }
  ]
}