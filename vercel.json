{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "app.xynapseai.net"
        }
      ],
      "destination": "/dashboard/:path*"
    },
    {
      "source": "/api/:path*",
      "has": [
        {
          "type": "host",
          "value": "api.xynapseai.net"
        }
      ],
      "destination": "/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "has": [
        {
          "type": "host",
          "value": "app.xynapseai.net"
        }
      ],
      "destination": "/auth/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "xynapseai.net"
        }
      ],
      "destination": "/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "has": [
        {
          "type": "host",
          "value": "api.xynapseai.net"
        }
      ],
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://app.xynapseai.net"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type,X-Recaptcha-Token,Authorization"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ]
}