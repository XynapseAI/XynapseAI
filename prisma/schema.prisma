// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  twitterHandle     String?
  twitterPFP        String?
  twitterAccessToken String?
  twitterConnected  Boolean           @default(false)
  walletAddress     String?
  points            Int               @default(0)
  tweetPoints       Int               @default(0)
  aiPoints          Int               @default(0)
  taskPoints        Int               @default(0)
  isCreator         Boolean           @default(false)
  isAiRank          Boolean           @default(false)
  tier              String            @default("Basic")
  isPlus            Boolean           @default(false)
  lastConnected     DateTime          @default(now())
  taskCompletions   TaskCompletion[]
  tweetAnalyses     TweetAnalysis[]   @relation("UserTweetAnalyses")
  aiInteractions    AIInteraction[]   @relation("UserAIInteractions")
  dailyAIInteractions DailyAIInteraction[] // Track daily AI interactions
  walletHistories   WalletHistory[]   @relation("UserWalletHistories")
}

model Task {
  id          String            @id @default(uuid())
  description String
  type        String
  link        String?
  points      Int
  isDaily     Boolean           @default(false)
  maxCompletions Int?           // Max completions for daily tasks (e.g., 5 for AI)
  completions TaskCompletion[]
}

model TaskCompletion {
  id           String    @id @default(uuid())
  userId       String
  taskId       String
  user         User      @relation(fields: [userId], references: [id])
  task         Task      @relation(fields: [taskId], references: [id])
  completedAt  DateTime  @default(now())
  completionCount Int    @default(1)
  @@unique([userId, taskId, completedAt])
}

model TweetAnalysis {
  id        String   @id @default(uuid())
  userId    String
  tweetId   String
  text      String
  points    Int
  createdAt DateTime @default(now())
  user      User     @relation("UserTweetAnalyses", fields: [userId], references: [id])
}

model AIInteraction {
  id              String   @id @default(uuid())
  userId          String
  query           String
  response        String?
  createdAt       DateTime @default(now())
  interactionType String   @default("chat") // Add interactionType to distinguish between chat and market
  user            User     @relation("UserAIInteractions", fields: [userId], references: [id])
}

model DailyAIInteraction {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime @default(now())
  count           Int      @default(1)
  interactionType String   @default("chat") // Add interactionType to track separately
  user            User     @relation(fields: [userId], references: [id])
  @@unique([userId, date, interactionType]) // Unique per user, date, and interaction type
}

model WalletHistory {
  id            Int      @id @default(autoincrement())
  userId        String
  walletAddress String
  action        String
  data          Json
  createdAt     DateTime @default(now())
  user          User     @relation("UserWalletHistories", fields: [userId], references: [id])
}