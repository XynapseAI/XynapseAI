generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admins {
  uid      String   @id @db.VarChar(100)
  is_admin Boolean?

  @@index([uid], map: "idx_admins_uid")
}

model api_keys {
  api_key    String    @id @db.VarChar(64)
  created_at DateTime? @db.Timestamp(6)
  expires_at DateTime? @db.Timestamp(6)
  active     Boolean?
}

model blockchain_cache {
  id        String   @id @db.VarChar(255)
  data      Json
  timestamp DateTime @db.Timestamptz(6)

  @@index([id], map: "idx_blockchain_cache_id")
}

model daily_ai_interactions {
  id               String    @id @db.VarChar(255)
  uid              String    @db.VarChar(100)
  date             DateTime  @db.Date
  interaction_type String    @db.VarChar(50)
  count            Int?      @default(0)
  points           Int?      @default(0)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)

  @@index([date], map: "idx_daily_ai_interactions_date")
  @@index([interaction_type], map: "idx_daily_ai_interactions_interaction_type")
  @@index([uid], map: "idx_daily_ai_interactions_uid")
}

model eth_price {
  id        String    @id @db.VarChar(10)
  price     Decimal?  @db.Decimal
  timestamp DateTime? @db.Timestamp(6)
}

model large_flows {
  id                    Int       @id @default(autoincrement())
  source_wallet_scanned String?   @db.VarChar(42)
  from_address          String?   @db.VarChar(42)
  to_address            String?   @db.VarChar(42)
  value_usd             Decimal?  @db.Decimal
  tx_hash               String?   @db.VarChar(66)
  block_time            DateTime? @db.Timestamp(6)
  from_nametag          String?
  to_nametag            String?
  timestamp_recorded    DateTime? @db.Timestamp(6)
  chain                 String?   @default("ethereum")

  @@index([source_wallet_scanned], map: "idx_large_flows_source_wallet")
  @@index([tx_hash], map: "idx_large_flows_tx_hash")
}

model nametags {
  address     String  @id @db.VarChar(42)
  nametag     String
  image       String? @default("/icons/default.png")
  description String? @default("")
  subcategory String? @default("Others")

  @@index([address], map: "idx_nametags_address")
}

model nametags_metadata {
  file_name     String   @id @db.VarChar(255)
  last_modified DateTime @db.Timestamp(6)
}

model pending_wallets_to_analyze {
  address             String    @id @db.VarChar(42)
  primary_wallet      String?   @db.VarChar(42)
  primary_wallet_name String?
  timestamp           DateTime? @db.Timestamp(6)

  @@index([address], map: "idx_pending_wallets_address")
}

model task_completions {
  id               String    @id @db.VarChar(255)
  user_id          String    @db.VarChar(100)
  task_id          String    @db.VarChar(50)
  completed_at     DateTime  @db.Date
  completion_count Int?      @default(1)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)

  @@index([completed_at], map: "idx_task_completions_completed_at")
  @@index([task_id], map: "idx_task_completions_task_id")
  @@index([user_id], map: "idx_task_completions_user_id")
}

model tasks {
  id              String    @id @db.VarChar(50)
  points          Int
  is_daily        Boolean?  @default(true)
  max_completions Int
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
}

model tweet_analyses {
  id         String    @id @db.VarChar(100)
  user_id    String    @db.VarChar(100)
  tweet_id   String    @db.VarChar(100)
  text       String
  points     Int?      @default(0)
  created_at DateTime  @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([tweet_id], map: "idx_tweet_analyses_tweet_id")
  @@index([user_id], map: "idx_tweet_analyses_user_id")
}

model users {
  id                 String              @id
  email              String              @unique
  google_id          String?             @unique
  profile_picture    String?
  email_verified     Boolean?            @default(false)
  google_name        String?
  wallet_address     String?
  points             BigInt?             @default(0)
  tweet_points       BigInt?             @default(0)
  ai_points          BigInt?             @default(0)
  task_points        BigInt?             @default(0)
  is_creator         Boolean?            @default(false)
  is_ai_rank         Boolean?            @default(false)
  tier               String?             @default("Basic")
  is_plus            Boolean?            @default(false)
  is_premium         Boolean?            @default(false)
  premium_expires_at DateTime?
  api_key            String?             @unique
  created_at         DateTime?           @default(now())
  updated_at         DateTime?           @updatedAt
  last_connected     DateTime?
  connected          Boolean?            @default(false)
  accounts           Account[]           @relation("UserToAccount")
  sessions           Session[]           @relation("UserToSession")
  verificationTokens VerificationToken[] @relation("UserToVerificationToken")

  @@index([ai_points], map: "idx_users_ai_points")
  @@index([email], map: "idx_users_email")
  @@index([points], map: "idx_users_points")
  @@index([task_points], map: "idx_users_task_points")
  @@index([tweet_points], map: "idx_users_tweet_points")
}

model wallet_analysis {
  wallet                        String    @id @db.VarChar(42)
  is_deposit                    Boolean?
  deposit_confidence_percentage Int?
  nametag                       String?
  image                         String?
  reason                        String?
  metrics                       Json?
  gemini_analysis               String?
  last_analysis                 DateTime? @db.Timestamp(6)

  @@index([wallet], map: "idx_wallet_analysis_wallet")
}

model wallet_histories {
  id             Int       @id @default(autoincrement())
  user_id        String?   @db.VarChar(100)
  wallet_address String?   @db.VarChar(42)
  action         String?   @db.VarChar(50)
  data           Json?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}

model watchlists {
  id             Int       @id @default(autoincrement())
  user_id        String
  wallet_address String
  name           String    @default("Unnamed Wallet")
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  @@unique([user_id, wallet_address], map: "unique_user_wallet")
  @@index([user_id], map: "idx_watchlists_user_id")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              users   @relation("UserToAccount", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         users    @relation("UserToSession", fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  user       users    @relation("UserToVerificationToken", fields: [identifier], references: [email], onDelete: Cascade)

  @@unique([identifier, token])
}