generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admins {
  uid      String   @id @db.VarChar(100)
  is_admin Boolean?

  @@index([uid], map: "idx_admins_uid")
}

model api_keys {
  created_at DateTime? @db.Timestamp(6)
  expires_at DateTime? @db.Timestamp(6)
  active     Boolean?
  api_key    String    @id @db.VarChar(64)
}

model blockchain_cache {
  id        String   @id @db.VarChar(255)
  data      Json
  timestamp DateTime @db.Timestamptz(6)

  @@index([id], map: "idx_blockchain_cache_id")
}

model daily_ai_interactions {
  id               String    @id @db.VarChar(255)
  uid              String    @db.VarChar(100)
  date             DateTime  @db.Date
  interaction_type String    @db.VarChar(50)
  count            Int?      @default(0)
  points           Int?      @default(0)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)

  @@index([date], map: "idx_daily_ai_interactions_date")
  @@index([interaction_type], map: "idx_daily_ai_interactions_interaction_type")
  @@index([uid], map: "idx_daily_ai_interactions_uid")
}

model eth_price {
  id        String    @id @db.VarChar(10)
  price     Decimal?  @db.Decimal
  timestamp DateTime? @db.Timestamp(6)
}

model large_flows {
  id                    Int       @id @default(autoincrement())
  source_wallet_scanned String?   @db.VarChar(42)
  from_address          String?   @db.VarChar(42)
  to_address            String?   @db.VarChar(42)
  value_usd             Decimal?  @db.Decimal
  tx_hash               String?   @db.VarChar(66)
  block_time            DateTime? @db.Timestamp(6)
  from_nametag          String?
  to_nametag            String?
  timestamp_recorded    DateTime? @db.Timestamp(6)
  chain                 String?   @default("ethereum")

  @@index([source_wallet_scanned], map: "idx_large_flows_source_wallet")
  @@index([tx_hash], map: "idx_large_flows_tx_hash")
}

model nametags {
  address     String  @id @db.VarChar(42)
  nametag     String
  image       String? @default("/icons/default.png")
  description String? @default("")
  subcategory String? @default("Others")

  @@index([address], map: "idx_nametags_address")
}

model nametags_metadata {
  file_name     String   @id @db.VarChar(255)
  last_modified DateTime @db.Timestamp(6)
}

model pending_wallets_to_analyze {
  address             String    @id @db.VarChar(42)
  primary_wallet      String?   @db.VarChar(42)
  primary_wallet_name String?
  timestamp           DateTime? @db.Timestamp(6)

  @@index([address], map: "idx_pending_wallets_address")
}

model task_completions {
  id               Int       @id @default(autoincrement())
  user_id          String?   @db.VarChar(100)
  task_id          String?   @db.VarChar(50)
  completion_count Int?      @default(1)
  points_earned    Int
  completed_at     DateTime? @default(now()) @db.Timestamp(6)
  tasks            tasks?    @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model tasks {
  id               String             @id @db.VarChar(50)
  description      String
  points           Int
  is_daily         Boolean?           @default(false)
  max_completions  Int?               @default(1)
  task_type        String             @db.VarChar(50)
  target_id        String?            @db.VarChar(255)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  task_completions task_completions[]
}

model tweet_analyses {
  id         String    @id @db.VarChar(100)
  user_id    String    @db.VarChar(100)
  tweet_id   String    @db.VarChar(100)
  text       String
  points     Int?      @default(0)
  created_at DateTime  @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([tweet_id], map: "idx_tweet_analyses_tweet_id")
  @@index([user_id], map: "idx_tweet_analyses_user_id")
}

model twitter_handles {
  id               Int       @id @default(autoincrement())
  user_id          String?   @unique @db.VarChar(100)
  twitter_handle   String    @db.VarChar(255)
  access_token     String
  refresh_token    String?
  token_expires_at DateTime? @db.Timestamp(6)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  profile_picture  String?
  users            users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                 String              @id
  email              String              @unique(map: "unique_email")
  google_id          String?             @unique(map: "unique_google_id")
  profile_picture    String?
  email_verified     Boolean?            @default(false)
  google_name        String?
  wallet_address     String?
  points             BigInt?             @default(0)
  task_points        BigInt?             @default(0)
  tier               String?             @default("Basic")
  is_premium         Boolean?            @default(false)
  api_key            String?             @unique
  created_at         DateTime?           @default(now())
  updated_at         DateTime?           @updatedAt
  last_connected     DateTime?
  connected          Boolean?            @default(false)
  ai_points          BigInt?             @default(0)
  is_ai_rank         Boolean?            @default(false)
  is_creator         Boolean?            @default(false)
  is_plus            Boolean?            @default(false)
  premium_expires_at DateTime?
  tweet_points       BigInt?             @default(0)
  twitter_handle     String?             @db.VarChar(255)
  api_key_hash       String?
  api_key_salt       String?
  accounts           Account[]           @relation("UserToAccount")
  payments           Payment[]           @relation("UserPayments")
  sessions           Session[]           @relation("UserToSession")
  verificationTokens VerificationToken[] @relation("UserToVerificationToken")
  legacyAccounts     accounts[]
  task_completions   task_completions[]
  twitter_handles    twitter_handles?

  @@index([ai_points], map: "idx_users_ai_points")
  @@index([email], map: "idx_users_email")
  @@index([points], map: "idx_users_points")
  @@index([task_points], map: "idx_users_task_points")
  @@index([tweet_points], map: "idx_users_tweet_points")
}

model wallet_analysis {
  wallet                        String    @id @db.VarChar(42)
  is_deposit                    Boolean?
  deposit_confidence_percentage Int?
  nametag                       String?
  image                         String?
  reason                        String?
  metrics                       Json?
  gemini_analysis               String?
  last_analysis                 DateTime? @db.Timestamp(6)

  @@index([wallet], map: "idx_wallet_analysis_wallet")
}

model wallet_histories {
  id             Int       @id @default(autoincrement())
  user_id        String?   @db.VarChar(100)
  wallet_address String?   @db.VarChar(42)
  action         String?   @db.VarChar(50)
  data           Json?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}

model watchlists {
  id             Int       @id @default(autoincrement())
  user_id        String
  wallet_address String
  name           String    @default("Unnamed Wallet")
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  @@unique([user_id, wallet_address], map: "unique_user_wallet")
  @@index([user_id], map: "idx_watchlists_user_id")
}

model Account {
  id                String  @id(map: "accounts_pkey") @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              users   @relation("UserToAccount", fields: [userId], references: [id], onDelete: Cascade, map: "accounts_userId_fkey")

  @@unique([provider, providerAccountId], map: "accounts_provider_providerAccountId_key")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         users    @relation("UserToSession", fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  user       users    @relation("UserToVerificationToken", fields: [identifier], references: [email], onDelete: Cascade)

  @@unique([identifier, token])
}

model accounts {
  id                Int       @id(map: "accounts_pkey1") @default(autoincrement())
  userid            String    @db.VarChar(255)
  type              String    @db.VarChar(255)
  provider          String    @db.VarChar(255)
  provideraccountid String    @db.VarChar(255)
  access_token      String?
  expires_at        BigInt?
  token_type        String?   @db.VarChar(255)
  scope             String?
  id_token          String?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)
  users             users     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@unique([provider, provideraccountid], map: "unique_provider_account")
  @@unique([provider, provideraccountid], map: "accounts_provider_unique")
}

model exchange_holders {
  id               Int      @id @default(autoincrement())
  exchange         String   @db.VarChar(100)
  chain            String   @db.VarChar(50)
  token_address    String?  @db.VarChar(100)
  total_tokens     Decimal  @db.Decimal
  total_value_usd  Decimal? @db.Decimal
  nametag          String?  @db.VarChar(100)
  wallet_addresses Json?
  update_date      DateTime @default(now()) @db.Timestamp(6)
  metadata         Json?
}

model holder_nametags {
  id               Int      @id @default(autoincrement())
  exchange_name    String   @db.VarChar(100)
  chain            String   @db.VarChar(50)
  token_address    String?  @db.VarChar(100)
  total_tokens     Decimal  @db.Decimal
  total_value_usd  Decimal  @db.Decimal
  nametag          String   @db.VarChar(255)
  wallet_addresses Json
  update_date      DateTime @db.Timestamp(6)
  metadata         Json?

  @@unique([exchange_name, chain, token_address], map: "unique_exchange_chain_token")
}

model token_holders {
  id             Int       @id @default(autoincrement())
  token_id       Int?
  coingecko_id   String    @db.VarChar(255)
  chain          String    @db.VarChar(50)
  token_address  String?   @db.VarChar(255)
  holder_address String    @db.VarChar(255)
  balance        Decimal?  @db.Decimal(36, 18)
  balance_usd    Decimal?  @db.Decimal(20, 2)
  percentage     Decimal?  @db.Decimal(10, 6)
  name_tag       String?   @db.VarChar(255)
  rank           Int?
  source         String?   @default("sim") @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  name           String?   @db.VarChar(255)
  image          String?   @db.VarChar(255)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  tokens         tokens?   @relation(fields: [token_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([coingecko_id, chain, holder_address])
  @@index([created_at], map: "idx_holders_created_at")
  @@index([image], map: "idx_holders_image")
  @@index([name], map: "idx_holders_name")
  @@index([coingecko_id, chain], map: "idx_holders_token_chain")
  @@index([updated_at], map: "idx_holders_updated_at")
}

model tokens {
  id               Int             @id @default(autoincrement())
  coingecko_id     String          @unique @db.VarChar(255)
  symbol           String          @db.VarChar(50)
  name             String          @db.VarChar(255)
  market_cap_rank  Int?
  platforms        Json?
  detail_platforms Json?
  created_at       DateTime?       @default(now()) @db.Timestamp(6)
  updated_at       DateTime?       @default(now()) @db.Timestamp(6)
  decimals         Int?
  image            String?         @db.VarChar(255)
  token_holders    token_holders[]

  @@index([coingecko_id], map: "idx_tokens_coingecko_id")
}

model wallet_holders {
  id              Int       @id @default(autoincrement())
  exchange_name   String    @db.VarChar(100)
  chain           String    @db.VarChar(50)
  holder_address  String    @db.VarChar(255)
  total_value_usd Decimal?  @db.Decimal(20, 2)
  token_count     Int?
  metadata        Json?
  name_tag        String?   @db.VarChar(255)
  image           String?   @db.VarChar(255)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)

  @@unique([exchange_name, chain, holder_address], map: "unique_wallet_holder")
  @@index([exchange_name], map: "idx_wallet_holders_exchange_name")
  @@index([chain], map: "idx_wallet_holders_chain")
}

model posted_transactions {
  hash      String    @id
  posted_at DateTime? @default(now()) @db.Timestamp(6)
}

model Payment {
  id         Int      @id @default(autoincrement())
  userId     String
  chargeId   String   @unique
  chargeCode String   @db.VarChar(100)
  amount     Float
  currency   String   @db.VarChar(10)
  status     String   @default("pending") @db.VarChar(50)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       users    @relation("UserPayments", fields: [userId], references: [id])

  @@index([userId], map: "idx_payment_userId")
}

model top_holders {
  id         Int       @id @default(autoincrement())
  chain      String    @db.VarChar(50)
  address    String    @db.VarChar(255)
  balance    Decimal?  @db.Decimal(36, 18)
  name_tag   String?   @db.VarChar(255)
  image      String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@unique([chain, address], map: "unique_chain_address")
  @@index([chain], map: "idx_top_holders_chain")
  @@index([address], map: "idx_top_holders_address")
}
